# GitHub OAuth App credentials
# Get these from https://github.com/settings/developers
#
# TWO OAUTH FLOWS SUPPORTED:
#
# 1. DEVICE FLOW (recommended, no localhost needed):
#    - Only needs GITHUB_CLIENT_ID
#    - No localhost callback URL required
#    - Works on any machine without port configuration
#    - User enters code at https://github.com/login/device
#
# 2. LOOPBACK FLOW (needs localhost):
#    - Needs both GITHUB_CLIENT_ID and GITHUB_CLIENT_SECRET
#    - Requires localhost callback URL configured in GitHub OAuth App
#    - Opens system browser, automatically captures callback
#
# AUTOMATIC FALLBACK:
#    If GITHUB_CLIENT_SECRET is not set, AgentDeck automatically
#    falls back from loopback flow to device flow.
#
# ============================================================
# SETUP INSTRUCTIONS:
# ============================================================
#
# FOR DEVICE FLOW ONLY (simplest, recommended):
#   1. Create OAuth App at https://github.com/settings/developers
#   2. Set Homepage URL: http://localhost (or any URL)
#   3. Leave Authorization callback URL empty or set to http://localhost
#   4. Copy Client ID below (no Client Secret needed for device flow)
#
# FOR LOOPBACK FLOW (needs both ID and Secret):
#   1. Create OAuth App at https://github.com/settings/developers
#   2. Set Homepage URL: http://localhost
#   3. Set Authorization callback URL: http://localhost:41864/agentdeck/callback
#   4. Copy both Client ID and Client Secret below
#
# ============================================================

GITHUB_CLIENT_ID=your_github_client_id_here

# Only needed for loopback flow (device flow works without it)
# If empty, AgentDeck automatically uses device flow
GITHUB_CLIENT_SECRET=

# Optional: GitHub OAuth scopes (space-separated)
# Default: read:user user:email
# GITHUB_SCOPES=read:user user:email
