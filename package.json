{
  "name": "agentdeck",
  "version": "0.1.0",
  "private": true,
  "description": "AgentDeck desktop agentic IDE MVP.",
  "type": "module",
  "main": "out/main/index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "typecheck": "npm run typecheck:main && npm run typecheck:preload && npm run typecheck:shared && npm run typecheck:services && npm run typecheck:agent-runtime && npm run typecheck:workbench && npm run typecheck:tests && npm run typecheck:build",
    "typecheck:main": "tsc --noEmit -p apps/desktop/tsconfig.main.json",
    "typecheck:preload": "tsc --noEmit -p apps/desktop/tsconfig.preload.json",
    "typecheck:shared": "tsc --noEmit -p packages/shared/tsconfig.json",
    "typecheck:services": "tsc --noEmit -p packages/services/tsconfig.json",
    "typecheck:agent-runtime": "tsc --noEmit -p packages/agent-runtime/tsconfig.json",
    "typecheck:workbench": "tsc --noEmit -p packages/workbench/tsconfig.json",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
    "typecheck:build": "tsc --noEmit -p tsconfig.build.json",
    "lint": "eslint .",
    "audit:security": "npm audit --audit-level=moderate --json",
    "test": "npm run test:unit && npm run test:architecture",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:architecture": "depcruise --config .dependency-cruiser.cjs apps packages"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "keytar": "^7.9.0",
    "monaco-editor": "^0.55.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "overrides": {
    "dompurify": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@monaco-editor/loader": "^1.5.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "dependency-cruiser": "17.4.3",
    "dotenv": "^17.4.2",
    "electron": "42.3.3",
    "electron-playwright-helpers": "^2.1.0",
    "electron-vite": "6.0.0-beta.1",
    "eslint": "10.4.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  }
}
